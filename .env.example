# === Transport Selection ===
# Choose: telegram (default) or slack
# TRANSPORT=telegram

# === Telegram Transport (required if transport=telegram) ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === Slack Transport (required if transport=slack) ===
# Bot User OAuth Token (OAuth & Permissions → Bot User OAuth Token)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-Level Token (Basic Information → App-Level Tokens, scope: connections:write)
# SLACK_APP_TOKEN=xapp-your-app-token

# Allowed user IDs (comma-separated, required)
# Telegram: numeric IDs (e.g. 123456789)
# Slack: member IDs starting with U (e.g. U01ABCDEF12)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccbot")
TMUX_SESSION_NAME=ccbot

# Claude command to run in new windows (optional, defaults to "claude")
CLAUDE_COMMAND=claude

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Notification filters (all default to true, set to false to suppress)
# CCBOT_SHOW_THINKING=true
# CCBOT_SHOW_TOOL_USE=true
# CCBOT_SHOW_TOOL_RESULT=true
# CCBOT_SHOW_USER_MESSAGES=true
# CCBOT_SHOW_STATUS=true
